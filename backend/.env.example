# ── Server ────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/booksalign?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_random_32+_char_string
JWT_EXPIRES_IN=1h

# ── Session (used only during OAuth handshake) ────────────────────
SESSION_SECRET=replace_with_another_random_32+_char_string

# ── Google OAuth (Google Cloud Console → APIs & Services → Credentials) ──
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ── Google Calendar (the admin's calendar where bookings are created) ──
GOOGLE_ADMIN_CALENDAR_ID=admin@booksalign.com.au

# ── Email (Nodemailer) ────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=hello@booksalign.com.au
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM="Books Align <hello@booksalign.com.au>"

# ── Admin dashboard login ─────────────────────────────────────────
# Generate hash: node -e "require('bcryptjs').hash('yourpassword',12).then(console.log)"
ADMIN_EMAIL=admin@booksalign.com.au
ADMIN_PASSWORD_HASH=$2b$12$replacethiswithyourbcrypthash

# ── Google reCAPTCHA v3 ───────────────────────────────────────────
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# ── Frontend URL (used for CORS + email links) ────────────────────
CLIENT_URL=http://localhost:5173
